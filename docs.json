{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Beni Documentation",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guide",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "best-practices"]
          },
          {
            "group": "Full Documentation",
            "pages": [
              "menus/dashboard",
              "menus/agents",
              "menus/knowledge-base",
              "menus/conversations",
              "menus/tools-and-integrations",
              {
                "group": "Settings",
                "pages": [
                  "menus/settings/organization",
                  "menus/settings/billing",
                  "menus/settings/members",
                  {
                    "group": "Security",
                    "pages": ["menus/settings/roles-and-permissions"]
                  },
                  "menus/settings/notifications",
                  {
                    "group": "Developer",
                    "pages": ["menus/settings/publishable-keys"]
                  }
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://docs.trybeni.ai",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://trybeni.ai/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@trybeni.ai"
      },
      {
        "label": "Beni Homepage",
        "href": "https://trybeni.ai"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/beniai"
    }
  }
}
